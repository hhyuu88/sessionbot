# ============================================================
# 号铺机器人代理转卖系统 - 环境变量配置模板
# 使用说明：
#   1. 复制此文件并重命名为 .env
#   2. 填写所有必填项（标注 [必填] 的配置）
#   3. 根据需要修改可选配置
#   4. 不要将 .env 文件提交到 Git！
# ============================================================

# ============================================================
# Telegram API 配置 [必填]
# 从 https://my.telegram.org/apps 获取
# ============================================================
API_ID=your_api_id_here
API_HASH=your_api_hash_here

# ============================================================
# 机器人配置 [必填]
# BOT_TOKEN 从 @BotFather 获取
# ============================================================
BOT_TOKEN=your_bot_token_here

# ============================================================
# 源机器人配置 [必填]
# 要代购的源号铺机器人用户名（带 @ 前缀）
# ============================================================
SOURCE_BOT_USERNAME=@source_shop_bot

# 代购账号 Session 文件名（不含 .session 后缀）
BUYER_ACCOUNT_SESSION=buyer_account

# ============================================================
# 管理员配置 [必填]
# 多个管理员用逗号分隔，例如：123456789,987654321
# 管理员 ID 可通过 @userinfobot 获取
# ============================================================
ADMIN_IDS=your_telegram_id_here

# ============================================================
# 数据库配置
# ============================================================
DATABASE_PATH=shop_proxy.db

# ============================================================
# 加价策略配置
# MARKUP_PERCENTAGE: 百分比加价（0.20 = 加价 20%）
# MARKUP_FIXED:      固定加价金额（U）
# 最终价格 = 成本价 × (1 + MARKUP_PERCENTAGE) + MARKUP_FIXED
# ============================================================
MARKUP_PERCENTAGE=0.20
MARKUP_FIXED=5

# ============================================================
# 库存同步配置
# ============================================================
# 库存同步间隔（秒），默认 1800（30分钟）
SYNC_INTERVAL=1800

# 低库存预警阈值（低于此值时发出警告）
LOW_STOCK_THRESHOLD=5

# 库存锁定超时（秒），默认 900（15分钟）
LOCK_TIMEOUT=900

# 同步失败最大重试次数
MAX_SYNC_RETRIES=3

# ============================================================
# 余额管理配置
# ============================================================
# 低余额预警阈值（U），低于此值时通知管理员
LOW_BALANCE_THRESHOLD=50

# 是否启用自动充值（true/false）
# 注意：自动充值需要配置支付方式，请谨慎启用
AUTO_RECHARGE_ENABLED=false

# 自动充值缓冲金额（U），实际充值 = 缺口 + 缓冲
# 例如：缺口 20U + 缓冲 50U = 充值 70U，避免频繁充值
RECHARGE_BUFFER_AMOUNT=50

# 余额检查间隔（秒），默认 1800（30分钟）
BALANCE_CHECK_INTERVAL=1800

# ============================================================
# 代购账号状态监控配置
# ============================================================
# 账号状态检查间隔（秒），默认 3600（1小时）
ACCOUNT_STATUS_CHECK_INTERVAL=3600
